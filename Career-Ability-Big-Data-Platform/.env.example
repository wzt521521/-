MYSQL_ROOT_PASSWORD=local-development-password
MYSQL_APP_USER=career_app
MYSQL_APP_PASSWORD=local-development-app-password
MYSQL_MIGRATOR_USER=career_migrator
MYSQL_MIGRATOR_PASSWORD=local-development-migrator-password
REDIS_PASSWORD=local-development-redis-password
JWT_SECRET=replace-this-with-at-least-32-random-bytes-before-running
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1:5173
# Set both values once only when bootstrapping an empty database, then remove INITIAL_ADMIN_PASSWORD.
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=

# ----- 大数据主通道（可选，答辩时启用）-----
# 设为 true 以启用 Kafka + Spark 主通道；留空或 false 则仅使用 Redis + Python 兜底
ANALYTICS_SPARK_ENABLED=false
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW_JOBS=raw-jobs
